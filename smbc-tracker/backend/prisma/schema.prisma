generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../data/smbc.db"
}

model Transaction {
  id             Int      @id @default(autoincrement())
  approvalNumber String   @unique
  date           DateTime
  merchant       String
  amount         Int
  category       String   @default("未分類")
  categorySource String   @default("auto")
  gmailMessageId String   @unique
  createdAt      DateTime @default(now())
}

model SyncState {
  id        Int    @id @default(autoincrement())
  historyId String @default("")
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isCustom  Boolean  @default(false)
  createdAt DateTime @default(now())
}
